# ============================================================
# Delta Saraswati -- Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
# ============================================================

# ------------------------------------------------------------
# Required
# ------------------------------------------------------------

# Groq API key for AI inference (Llama 3.3 70B).
# Obtain one at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ------------------------------------------------------------
# Optional -- Vercel KV (Redis)
# ------------------------------------------------------------
# These are auto-populated when you create a KV store in the
# Vercel dashboard and link it to the project. Only needed for
# server-side caching of API responses and AI summaries.

KV_REST_API_URL=
KV_REST_API_TOKEN=

# ------------------------------------------------------------
# App Config
# ------------------------------------------------------------

# Base URL for the Delta Exchange REST API.
# Production (India): https://api.india.delta.exchange/v2
NEXT_PUBLIC_DELTA_API_BASE=https://api.india.delta.exchange/v2

# Display name used in the UI header and metadata tags.
NEXT_PUBLIC_APP_NAME=Delta Saraswati

# Canonical site URL used for Open Graph tags, sitemaps, and
# absolute links. Set to your Vercel deployment URL or custom domain.
NEXT_PUBLIC_SITE_URL=https://delta-saraswati.vercel.app
